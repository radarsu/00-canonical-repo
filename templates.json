{
    "scope": "@app_/",
    "shell": [
        "package.json",
        "pnpm-workspace.yaml",
        "turbo.json",
        ".gitignore",
        ".npmrc",
        ".editorconfig",
        ".oxlintrc.json",
        ".prettierignore",
        ".prettierrc.json",
        "commitlint.config.ts",
        "docker-compose.yml",
        ".env.example",
        ".githooks"
    ],
    "shared": ["_tools/tsconfig", "_tools/localhost-https", "_libs/ui"],
    "templates": {
        "full-stack": {
            "label": "Full-stack (Vue + Hono + oRPC)",
            "description": "Vue 3 SPA + Hono/oRPC API + Prisma, one deployable app.",
            "instance": ["_apps/api", "_apps/web", "_libs/api-contract", "_libs/prisma"],
            "preview": { "dev": "turbo run dev --filter=\"@app_/{name}-*\"", "port": 4701 }
        },
        "landing": {
            "label": "Landing page (Astro)",
            "description": "Static marketing site (Astro + Tailwind).",
            "instance": ["_apps/landing"],
            "preview": { "dev": "turbo run dev --filter=\"@app_/{name}\"", "port": 4321 }
        }
    }
}
