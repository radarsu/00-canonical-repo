{
    "scope": "@app_/",
    "shell": [
        "package.json",
        "pnpm-workspace.yaml",
        "turbo.json",
        ".gitignore",
        ".npmrc",
        ".editorconfig",
        ".oxlintrc.json",
        ".prettierignore",
        ".prettierrc.json",
        "commitlint.config.ts",
        "docker-compose.yml",
        ".env.example",
        ".githooks"
    ],
    "shared": ["_tools/tsconfig", "_tools/localhost-https", "_libs/ui"],
    "templates": {
        "api": {
            "label": "API (Hono)",
            "description": "Hono + oRPC API on Bun, with Prisma and Better Auth.",
            "instance": ["_apps/api", "_libs/api-contract", "_libs/prisma"],
            "previews": [{ "package": "api", "dev": "pnpm --filter {pkg} dev", "port": 6480, "env": { "API_PORT": "{port}", "WEB_ORIGIN": "{previewUrl:web}" } }]
        },
        "web": {
            "label": "Web app (Vue)",
            "description": "Vue 3 SPA (Vite + PrimeVue + TanStack Query).",
            "instance": ["_apps/web", "_libs/api-contract"],
            "previews": [{ "package": "web", "dev": "pnpm --filter {pkg} dev", "port": 4701, "env": { "API_URL": "{previewUrl:api}" } }]
        },
        "landing": {
            "label": "Landing page (Astro)",
            "description": "Static marketing site (Astro + Tailwind).",
            "instance": ["_apps/landing"],
            "previews": [{ "package": "landing", "dev": "pnpm --filter {pkg} dev", "port": 4321 }]
        }
    }
}
