{
    "name": "@app_/root",
    "version": "0.0.0",
    "private": true,
    "license": "UNLICENSED",
    "scripts": {
        "dev": "([ -f .env ] || cp .env.example .env) && pnpm db:up && turbo run dev",
        "build": "turbo run build",
        "typecheck": "turbo run typecheck",
        "check": "pnpm typecheck && pnpm lint && pnpm format:check",
        "lint": "oxlint --deny-warnings",
        "lint:fix": "oxlint --fix",
        "format": "prettier --write .",
        "format:check": "prettier --check .",
        "db:up": "docker compose up -d --wait postgres && pnpm db:migrate:deploy",
        "db:down": "docker compose down",
        "db:clear": "docker compose down -v && docker compose up -d --wait postgres && pnpm db:migrate:deploy",
        "db:reset": "pnpm --filter @app_/prisma run reset",
        "db:generate": "pnpm --filter @app_/prisma run generate",
        "db:migrate:dev": "pnpm --filter @app_/prisma run migrate:dev",
        "db:migrate:deploy": "pnpm --filter @app_/prisma run migrate:deploy",
        "db:studio": "pnpm --filter @app_/prisma run studio",
        "trace:up": "docker compose up -d --wait signoz",
        "trace:down": "docker compose stop signoz",
        "diff:stat": "git diff HEAD --shortstat",
        "clean": "find . -type d \\( -name 'node_modules' -o -name '.cache' -o -name 'deploy' -o -name 'dist' -o -name '.turbo' -o -name 'generated' -o -name 'out-tsc' \\) -prune -exec rm -rf '{}' +",
        "prepare": "git rev-parse --git-dir > /dev/null 2>&1 && git config core.hooksPath .githooks || true",
        "postinstall": "[ -f .env ] || cp .env.example .env"
    },
    "devDependencies": {
        "@commitlint/cli": "catalog:",
        "@commitlint/config-conventional": "catalog:",
        "@types/node": "catalog:",
        "oxlint": "catalog:",
        "prettier": "catalog:",
        "tslib": "catalog:",
        "turbo": "catalog:",
        "typescript": "catalog:"
    },
    "engines": {
        "node": "24.18.0",
        "pnpm": "11.9.0"
    },
    "packageManager": "pnpm@11.9.0"
}
