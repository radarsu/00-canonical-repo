/* Prisma is source-first like the other libs: consumers resolve types straight from client.ts (which
 * re-exports ./generated), and Bun runs it directly — no dist. This config is editor-only (no script runs
 * it): it makes opening the package resolve the generated client. `prisma generate` produces ./generated. */
{
    "compilerOptions": {
        "baseUrl": "./",
        "exactOptionalPropertyTypes": false,
        "noEmit": true,
        "noPropertyAccessFromIndexSignature": false,
        "tsBuildInfoFile": "./.cache/tsbuildinfo"
    },
    "include": ["./client.ts", "./generated/**/*"],
    "extends": "../../_tools/tsconfig/tsconfig.base.json"
}
