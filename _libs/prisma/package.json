{
    "name": "@app_/prisma",
    "version": "0.0.0",
    "private": true,
    "type": "module",
    "main": "client.ts",
    "types": "client.ts",
    "exports": {
        ".": {
            "types": "./client.ts",
            "default": "./client.ts"
        }
    },
    "files": [
        "client.ts",
        "generated",
        "migrations",
        "schema.prisma",
        "prisma.config.ts"
    ],
    "scripts": {
        "build": "DATABASE_URL=postgresql://placeholder prisma generate --no-hints",
        "generate": "DATABASE_URL=postgresql://placeholder prisma generate --no-hints",
        "reset": "prisma migrate reset",
        "migrate:dev": "prisma migrate dev",
        "migrate:deploy": "prisma migrate deploy",
        "push": "prisma db push --accept-data-loss",
        "studio": "prisma studio"
    },
    "dependencies": {
        "@prisma/adapter-pg": "catalog:",
        "@prisma/client": "catalog:",
        "tslib": "catalog:"
    },
    "devDependencies": {
        "@app_/tsconfig": "workspace:*",
        "prisma": "catalog:",
        "typescript": "catalog:"
    }
}
