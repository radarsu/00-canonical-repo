/* The UI lib is consumed directly from source (main/exports → ./src/index.ts); this config exists only
 * for standalone type-checking via `pnpm --filter @app_/ui typecheck`. */
{
    "compilerOptions": {
        "baseUrl": "./",
        "noEmit": true,
        "rootDir": "./src",
        "tsBuildInfoFile": "./.cache/tsbuildinfo"
    },
    "include": ["./src/**/*"],
    "extends": "@app_/tsconfig/tsconfig.angular.json"
}
