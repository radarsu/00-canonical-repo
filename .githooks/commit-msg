#!/bin/sh
# Enforces Conventional Commits via commitlint. Wired by the root `prepare` script, which points
# git at this dir (core.hooksPath=.githooks) on install — no husky/lefthook framework needed.
# Uses bunx (Bun runs commitlint.config.ts directly). Skip gracefully if deps aren't installed yet.
command -v bunx >/dev/null 2>&1 || exit 0
[ -d node_modules/@commitlint ] || exit 0
exec bunx commitlint --edit "$1"
