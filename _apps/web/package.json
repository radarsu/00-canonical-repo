{
    "name": "@app_/web",
    "version": "0.0.0",
    "private": true,
    "type": "module",
    "files": [
        "dist"
    ],
    "scripts": {
        "dev": "esbuild src/environments/environment.local.ts --bundle --target=es2024 --outfile=public/assets/js/env.js && vite",
        "watch": "esbuild src/environments/environment.local.ts --bundle --target=es2024 --outfile=public/assets/js/env.js && vite",
        "build": "vue-tsc --noEmit -p tsconfig.app.json && vite build && esbuild src/environments/environment.deployment.ts --bundle --minify --target=es2024 --outfile=dist/assets/js/env.js",
        "typecheck": "vue-tsc --noEmit -p tsconfig.app.json"
    },
    "dependencies": {
        "@app_/api-contract": "workspace:*",
        "@app_/localhost-https": "workspace:*",
        "@app_/ui": "workspace:*",
        "@tanstack/vue-query": "catalog:",
        "@orpc/client": "catalog:",
        "@orpc/contract": "catalog:",
        "@orpc/openapi-client": "catalog:",
        "@primeuix/themes": "catalog:",
        "better-auth": "catalog:",
        "primeicons": "catalog:",
        "primevue": "catalog:",
        "tailwind-merge": "catalog:",
        "tslib": "catalog:",
        "vue": "catalog:",
        "vue-router": "catalog:",
        "zod": "catalog:"
    },
    "devDependencies": {
        "@app_/tsconfig": "workspace:*",
        "@tailwindcss/vite": "catalog:",
        "@types/node": "catalog:",
        "@vitejs/plugin-vue": "catalog:",
        "esbuild": "catalog:",
        "tailwindcss": "catalog:",
        "typescript": "catalog:",
        "vite": "catalog:",
        "vue-tsc": "catalog:"
    }
}
