{
    // Editor and explorer.
    "editor.defaultFormatter": "esbenp.prettier-vscode",
    "editor.formatOnSave": true,
    "editor.codeActionsOnSave": {
        "source.fixAll.oxc": "explicit"
    },
    "files.exclude": {
        "**/.cache": true,
        "**/.turbo": true,
        "**/dist": true,
        "**/generated": true,
        "**/out-tsc": true
    },
    "window.title": "${folderName}",

    // File nesting.
    "explorer.fileNesting.enabled": true,
    "explorer.fileNesting.expand": false,
    "explorer.fileNesting.patterns": {
        // * Environment.
        ".env.local": ".env.local.template, .env.docker, .env.docker.template",

        // * Formats
        "*.ttf": "$(capture).eot, $(capture).otf, $(capture).woff, $(capture).woff2, $(capture).svg",
        "icon.original.png": "icon-*.png, favicon.ico",

        // * Node.js
        "package.json": ".editorconfig, .gitignore, .npmrc, .prettierrc.json, pnpm-workspace.yaml, pnpm-lock.yaml, README.md, docker-compose.yml, Dockerfile, turbo.json, commitlint.config.ts, .oxlintrc.json, .prettierignore, .env, .env.example, CLAUDE.md, AGENTS.md"
    },

    // TitleBar with different color per repository.
    "workbench.colorCustomizations": {
        // Choose colors from 800-950 palette: https://tailwindcss.com/docs/customizing-colors
        "titleBar.activeBackground": "#434200",
        "titleBar.inactiveBackground": "#000000"
    },

    // Open SVG as text.
    "workbench.editorAssociations": {
        "*.svg": "default"
    },
    "workbench.tree.enableStickyScroll": false
}
