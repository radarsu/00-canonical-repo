# Copy to `.env` (git-ignored) and fill in. @puristic/env derives each var name by SCREAMING_SNAKE-casing
# the config schema path (see _apps/api/src/config.ts): database.url → DATABASE_URL, api.port → API_PORT.

# Postgres — matches docker-compose.yml (host port 5439).
DATABASE_URL=postgresql://app:app@localhost:5439/app

# Better Auth session signing key — generate with: openssl rand -base64 32
BETTER_AUTH_SECRET=replace-me-with-a-32-char-random-string

# Browser-facing origin of the API. The SPA calls it directly (CORS-allowed); also Better Auth's base URL
# and the OAuth redirect base. Dev is https so cookies + FedCM work: https://localhost:6480.
API_URL=https://localhost:6480

# Origin the Angular app is served from (CORS allow-origin + Better Auth trusted origin).
WEB_ORIGIN=https://localhost:4701

# API server port.
API_PORT=6480

# Logging (pino). LOG_LEVEL: fatal|error|warn|info|debug|trace|silent. LOG_PRETTY: true = colorized dev
# output, false = single-line JSON (defaults to pretty unless NODE_ENV=production).
LOG_LEVEL=info
LOG_PRETTY=

# OpenTelemetry (optional, off by default). Standard OTEL_* vars, read directly by the SDK. Uncomment and run
# `pnpm trace:up` (Jaeger UI: http://localhost:16686) to enable tracing; logs then carry trace_id/span_id.
# OTEL_EXPORTER_OTLP_ENDPOINT=http://localhost:4318
# OTEL_SERVICE_NAME=safe-parking-api

# Dev TLS — paths to the committed @app_/localhost-https cert/key (its CA is trusted locally). Leave empty
# in prod (TLS terminated by the proxy).
API_HTTPS_KEY=./node_modules/@app_/localhost-https/localhost.key
API_HTTPS_CERT=./node_modules/@app_/localhost-https/localhost.crt

# Google OAuth (optional) — create at https://console.cloud.google.com/apis/credentials
# Redirect URI to register: https://localhost:6480/api/auth/callback/google
# Leave empty to use email+password sign-in only (enabled by default for local dev).
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
