/* Shared base for the Angular app (web) and Angular libs (ui). Holds the deviations from
 * tsconfig.base.json that Angular's bundler build requires. Path options (baseUrl/outDir/
 * rootDir/tsBuildInfoFile) stay in each package's own tsconfig.json because `extends`
 * resolves those relative to the file that defines them. */
{
    "compilerOptions": {
        "composite": false,
        "declaration": false,
        "declarationMap": false,
        "esModuleInterop": true,
        "exactOptionalPropertyTypes": false,
        "lib": ["ES2024", "dom", "esnext.asynciterable"],
        "module": "esnext",
        "moduleResolution": "bundler",
        "resolveJsonModule": true,
        "target": "ES2023",
        "useDefineForClassFields": false
    },
    "angularCompilerOptions": {
        "enableI18nLegacyMessageIdFormat": false,
        "strictInjectionParameters": true,
        "strictInputAccessModifiers": true,
        "strictTemplates": true
    },
    "extends": "./tsconfig.base.json"
}
